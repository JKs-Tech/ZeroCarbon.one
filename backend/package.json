{
  "name": "@zerocarbon/backend",
  "version": "1.0.0",
  "description": "ZeroCarbon.one AI Utility Bill Extraction Platform — Backend API",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx src/workers/index.ts",
    "dev:worker:watch": "tsx watch src/workers/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.34.5",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.3",
    "multer": "^2.2.0",
    "openai": "^6.47.0",
    "pdf-parse": "^2.4.5",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.5",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
