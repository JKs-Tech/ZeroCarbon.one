# Copy to backend/.env and fill in JWT_SECRET + OPENAI_API_KEY.
# Used for both local development and Docker Compose (Compose overrides Mongo/Redis hosts).

# --- Application ---
NODE_ENV=development
PORT=3000
APP_NAME=zerocarbon-backend
APP_VERSION=1.0.0
LOG_LEVEL=info

# --- MongoDB (Compose overrides host to "mongodb") ---
MONGODB_URI=mongodb://127.0.0.1:27017/zerocarbon
MONGODB_DB_NAME=zerocarbon

# --- Redis (Compose overrides host to "redis") ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- BullMQ ---
BULLMQ_PREFIX=zc
QUEUE_CONCURRENCY=2
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_MS=2000
QUEUE_LOCK_DURATION_MS=900000
QUEUE_STALLED_INTERVAL_MS=60000
QUEUE_MAX_STALLED_COUNT=5

# --- Security / HTTP ---
# Local Vite UI: http://localhost:5173 | Docker UI: http://localhost:8080
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20000
BODY_JSON_LIMIT=1mb
BODY_URLENCODED_LIMIT=1mb
TRUST_PROXY=false

# --- Health / process ---
HEALTH_MONGO_TIMEOUT_MS=2000
HEALTH_REDIS_TIMEOUT_MS=2000
SHUTDOWN_TIMEOUT_MS=10000

# --- Auth (required) ---
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=12
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# --- Storage / upload ---
MAX_UPLOAD_SIZE=10485760
UPLOAD_MAX_BYTES=10485760
MAX_FILES_PER_UPLOAD=20
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads

# --- OCR ---
OCR_TIMEOUT=120000
OCR_LANGUAGE=eng
OCR_MIN_TEXT_LENGTH=80
OCR_QUALITY_THRESHOLD=0.55
TEMP_DIRECTORY=./tmp/ocr
OCR_PDF_RASTER_DPI=200
OCR_CONFIDENCE_RETRY_THRESHOLD=55
OCR_RETRY_RASTER_DPI=300

# --- AI (required) ---
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_TIMEOUT=120000
OPENAI_REASONING_EFFORT=low
MAX_AI_RETRIES=2
TEMPERATURE=1
MAX_OUTPUT_TOKENS=8192
AI_VISION_ENABLED=true

# --- Validation ---
MAX_ALLOWED_AMOUNT=10000000
MAX_ALLOWED_CONSUMPTION=1000000
MAX_ALLOWED_QUANTITY=1000000
ENABLE_DUPLICATE_CHECK=true
